aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; omarchy-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; omarchy-pkg-aur-add $2 && setsid gtk-launch $3"
}

